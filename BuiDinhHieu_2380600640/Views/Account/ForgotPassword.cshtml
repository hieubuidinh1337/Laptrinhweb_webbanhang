@using BuiDinhHieu_2380600640.Models.ViewModels
@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container" style="max-width:500px;margin:var(--sp-8) auto;padding:0 var(--sp-4)">
    <div style="text-align:center; margin-bottom:var(--sp-6)">
        <h1 style="font-family:var(--ff-display);font-size:var(--fs-display-lg);font-weight:300;">
            Quên <em>mật khẩu?</em>
        </h1>
        <p style="color:var(--c-muted); margin-top:var(--sp-2)">Nhập email đăng ký của bạn để nhận liên kết đặt lại mật khẩu.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert--success" style="background:rgba(59,109,17,0.08);border:1px solid rgba(59,109,17,0.25);border-radius:var(--r-md);padding:var(--sp-4);margin-bottom:var(--sp-5);color:var(--c-success);font-size:var(--fs-sm)">
            <i class="fa-solid fa-circle-check" style="margin-right:8px"></i> @TempData["Success"]
        </div>
    }

    <div style="background:var(--c-surface);border:1px solid var(--c-border);border-radius:var(--r-lg);padding:var(--sp-6);box-shadow:var(--sh-sm)">

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" style="color:var(--c-danger); margin-bottom:var(--sp-3); font-size:var(--fs-sm);"></div>
        }

        <form method="post" action="/tai-khoan/quen-mat-khau" novalidate>
            @Html.AntiForgeryToken()

            <div class="form__group @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "has-error" : "")">
                <label class="form__label" asp-for="Email" style="display:block; margin-bottom:8px; font-weight:500;">Email của bạn <span aria-hidden="true" style="color:var(--c-danger)">*</span></label>
                <input class="form__input" asp-for="Email" type="email" required placeholder="ví dụ: admin@DinhHieu.com" style="width:100%; padding:10px; border:1px solid var(--c-border); border-radius:var(--r-md);" />
                <span class="form__error" asp-validation-for="Email" style="color:var(--c-danger); font-size:var(--fs-xs); display:block; margin-top:4px;"></span>
            </div>

            <button type="submit" class="btn btn--solid btn--lg" style="width:100%; margin-top:var(--sp-4); background:var(--c-ink); color:#fff; padding:12px 24px; border:none; border-radius:var(--r-md); cursor:pointer;">
                Gửi liên kết khôi phục
            </button>
        </form>

        <div style="text-align:center; margin-top:var(--sp-5); font-size:var(--fs-sm);">
            <a href="/Account/Login" style="color:var(--c-ink-mid); text-decoration:none; transition:color var(--dur-fast)">
                <i class="fa-solid fa-arrow-left" style="margin-right:4px"></i> Quay lại trang đăng nhập
            </a>
        </div>
    </div>
</div>