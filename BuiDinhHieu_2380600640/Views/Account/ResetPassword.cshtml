@using BuiDinhHieu_2380600640.Models.ViewModels
@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="container" style="max-width:500px;margin:var(--sp-8) auto;padding:0 var(--sp-4)">
    <div style="text-align:center; margin-bottom:var(--sp-6)">
        <h1 style="font-family:var(--ff-display);font-size:var(--fs-display-lg);font-weight:300;">
            Đặt lại <em>mật khẩu</em>
        </h1>
        <p style="color:var(--c-muted); margin-top:var(--sp-2)">Tài khoản: <strong>@Model.Email</strong></p>
    </div>

    <div style="background:var(--c-surface);border:1px solid var(--c-border);border-radius:var(--r-lg);padding:var(--sp-6);box-shadow:var(--sh-sm)">

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" style="color:var(--c-danger); margin-bottom:var(--sp-3); font-size:var(--fs-sm);"></div>
        }

        <form method="post" action="/tai-khoan/dat-lai-mat-khau" novalidate>
            @Html.AntiForgeryToken()

            @* Lưu ẩn Token và Email để submit lên controller *@
            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />

            <div class="form__group @(ViewData.ModelState["NewPassword"]?.Errors.Count > 0 ? "has-error" : "")" style="margin-bottom:var(--sp-4)">
                <label class="form__label" asp-for="NewPassword">Mật khẩu mới hoàn toàn <span aria-hidden="true">*</span></label>
                <input class="form__input" asp-for="NewPassword" type="password" required style="width:100%; padding:10px; border:1px solid var(--c-border); border-radius:var(--r-md);" />
                <span class="form__error" asp-validation-for="NewPassword" style="color:var(--c-danger); font-size:var(--fs-xs);"></span>
            </div>

            <div class="form__group @(ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0 ? "has-error" : "")" style="margin-bottom:var(--sp-4)">
                <label class="form__label" asp-for="ConfirmPassword">Xác nhận lại mật khẩu <span aria-hidden="true">*</span></label>
                <input class="form__input" asp-for="ConfirmPassword" type="password" required style="width:100%; padding:10px; border:1px solid var(--c-border); border-radius:var(--r-md);" />
                <span class="form__error" asp-validation-for="ConfirmPassword" style="color:var(--c-danger); font-size:var(--fs-xs);"></span>
            </div>

            <button type="submit" class="btn btn--solid btn--lg" style="width:100%; background:var(--c-ink); color:#fff; padding:12px 24px; border:none; border-radius:var(--r-md); cursor:pointer; margin-top:var(--sp-2)">
                Cập nhật mật khẩu mới
            </button>
        </form>
    </div>
</div>